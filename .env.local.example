# ============================================
# WhatsApp Agent Dashboard - Environment Config
# ============================================
# Copy this file to .env.local and fill in your values

# --- FREE LOCAL LLM (Ollama) ---
# Install Ollama: https://ollama.ai
# Run: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# --- FREE CLOUD LLM (Groq - Free Tier) ---
# Get free API key: https://console.groq.com
# Free limits: 14,400 req/day, 500,000 tokens/min (varies by model)
GROQ_API_KEY=your_groq_api_key_here

# --- FREE CLOUD LLM (OpenRouter - Has Free Models) ---
# Get free API key: https://openrouter.ai
# Free models: meta-llama/llama-3.1-8b-instruct:free, google/gemma-2-9b-it:free
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- WHATSAPP (Free via whatsapp-web.js) ---
# No API key needed! Uses WhatsApp Web reverse engineering
# Just scan the QR code in the dashboard
WHATSAPP_ENABLED=true

# --- VOICE CALLS ---
# Option 1: VAPI (Free tier: 10 min/month for testing)
# Sign up: https://vapi.ai
VAPI_API_KEY=your_vapi_api_key_here

# Option 2: Twilio (Free trial: $15 credit)
# Sign up: https://twilio.com
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_number

# --- DATABASE ---
# SQLite database path (relative to project root)
DB_PATH=./data/agents.db

# --- APP ---
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000
